<script>
const elements = document.querySelectorAll('.fade');

window.addEventListener('scroll', () => {
    elements.forEach(el => {
        if(el.getBoundingClientRect().top < window.innerHeight - 100){
            el.classList.add('show');
        }
    });
});

window.onload = () => {
    elements.forEach(el => {
        setTimeout(() => el.classList.add('show'), 200);
    });
};
</script>

